# Admin credentials (required)
ADMIN_USER=admin
ADMIN_PASS=change-me

# JWT secret (auto-generated if empty, set for persistence across restarts)
ADMIN_JWT_SECRET=

# Server
PORT=8080
NODE_ENV=development
PUBLIC_BASE_URL=

# Game settings
HU_START_SB=
HU_START_BB=

# Avatar upload limit (bytes, default 2MB)
AVATAR_MAX_BYTES=2000000

# Solana (legacy, will be replaced by CorePass)
# SOLANA_RPC_URL=
# SOLANA_TOKEN_MINT=
# SOLANA_TOKEN_THRESHOLD=
