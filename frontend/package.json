{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start:back": "npm --prefix ../backend start",
    "start:back:clean": "node ../backend/scripts/port_guard.mjs 8080 || true && set GE_PRIMARY_MS=1000&& set GE_BANK_MS=0&& npm --prefix ../backend start",
    "e2e": "start-server-and-test start:back:clean http://localhost:8080/health \"playwright test\"",
    "e2e:ui": "playwright test --ui",
    "test:overlay": "start-server-and-test start:back:clean http://localhost:8080/health \"playwright test tests/hu-allin-overlay-timing.spec.ts\""
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@playwright/test": "^1.55.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "start-server-and-test": "^2.1.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.43.0",
    "vite": "^7.1.6"
  }
}
